{
  "family": "innovatech-frontend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::325826732988:role/LabRole",
  "taskRoleArn": "arn:aws:iam::325826732988:role/LabRole",
  "containerDefinitions": [
    {
      "name": "innovatech-frontend",
      "image": "325826732988.dkr.ecr.us-east-1.amazonaws.com/innovatech-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "VENTAS_API_URL", "value": "/api/v1/ventas" },
        { "name": "DESPACHOS_API_URL", "value": "/api/v1/despachos" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/innovatech-frontend",
          "awslogs-region": "us-east-1",
          "awslogs-create-group": "true",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
